# Password to access the app (REQUIRED)
APP_PASSWORD=change-this-to-a-strong-password

# Database location (default: ./data/feed-me-maybe.db)
# In Docker, this is /data/feed-me-maybe.db
DATABASE_URL=./data/feed-me-maybe.db

# Server host and port (defaults: 0.0.0.0:3000)
HOST=0.0.0.0
PORT=3000

# Application secret for session encryption
# Generate with: openssl rand -hex 32
APP_SECRET=

# --- AI Provider Settings (optional) ---
# Configured via UI, but can be set here for pre-configuration
# PROVIDER=openai
# MODEL=gpt-4o
# API_KEY=sk-...
