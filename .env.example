# Password to access the app (REQUIRED)
APP_PASSWORD=change-this-to-a-strong-password

# Database location
# Local development default:
DATABASE_URL=./data/feed-me-maybe.db
# Docker / CapRover:
# DATABASE_URL=/app/data/feed-me-maybe.db

# Server host and port (defaults: 0.0.0.0:3000)
HOST=0.0.0.0
PORT=3000

# Reverse-proxy headers used by SvelteKit behind CapRover / NGINX
# These are set automatically in the Docker image, so you usually do not
# need to define them yourself.
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# PORT_HEADER=x-forwarded-port

# Application secret for session encryption and AI key encryption
# Generate with: openssl rand -hex 32
# Keep this stable across deploys if you use encrypted provider API keys.
APP_SECRET=

# --- AI Provider Settings (optional) ---
# Usually configured in the UI, but can be set here for pre-configuration
# PROVIDER=openai
# MODEL=gpt-4o
# API_KEY=sk-...
